  "keyFeatures": [
    "Community incident reporting for accessibility barriers and good practices",
    "Interactive map visualization of all reported incidents using Leaflet",
    "Real-time chat with administrators via Socket.io",
    "Web Push Notifications with VAPID authentication for live updates",
    "User dashboard to manage personal incident reports",
    "Blog for accessibility news and updates in the Canary Islands",
    "JWT and session-based dual authentication system",
    "OpenLDAP integration for centralized user directory and password management",
    "Admin dashboard (EJS) for platform management",
    "Multi-language support with react-i18next and MyMemory translation API",
    "Image uploads to DigitalOcean Spaces (S3-compatible storage)",
    "Email notifications via Resend API"
  ],
